# ══════════════════════════════════════════
# Grants By AI — Environment Configuration
# ══════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].

# ── Database ──────────────────────────────
# [REQUIRED] PostgreSQL connection string (Neon recommended for production)
# For local dev with SQLite, use: file:./dev.db
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ── NextAuth ──────────────────────────────
# [REQUIRED] Base URL for auth callbacks
NEXTAUTH_URL="http://localhost:3000"

# [REQUIRED] JWT signing secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# [RECOMMENDED] AES-256-GCM key for encrypting sensitive vault fields (EIN, routing #, account #)
# Generate with: openssl rand -hex 32
# If unset, a key is derived from NEXTAUTH_SECRET (dev only). Set explicitly in production.
FIELD_ENCRYPTION_KEY=""

# [UI flag] Set to "true" once an automated email service (Resend/SendGrid/etc.) is wired
# up for password-reset emails. While "false" (default), the forgot-password success page
# asks users to contact support instead of waiting for an email that won't arrive.
NEXT_PUBLIC_EMAIL_ENABLED="false"

# ── OAuth Providers (optional) ────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── AI (Google Gemini) ────────────────────
# Powers all AI features: chat, matching, writing assistant, eligibility
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ── Email (optional) ─────────────────────
# Primary: Resend (https://resend.com)
RESEND_API_KEY=""

# Fallback: SMTP relay (any SMTP-to-HTTP bridge)
SMTP_HOST=""
SMTP_USER=""
SMTP_PASS=""

# Default sender address
EMAIL_FROM="Grants By AI <notifications@grantsby.ai>"

# ── External APIs (optional) ─────────────
# Candid Foundation Directory — https://candid.org/use-our-data/api
CANDID_API_KEY=""

# ── Security ─────────────────────────────
# Admin API key for protected endpoints (e.g., /api/grants/sync)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=""

# Vercel Cron job authentication token
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ── Application ──────────────────────────
# Public-facing URL (used in email templates)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
