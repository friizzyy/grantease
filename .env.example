# Admin Key (for protected API routes)
ADMIN_API_KEY="your-admin-api-key-here"

# Email (optional for alerts)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM=""

# External APIs (for grant ingestion)
GRANTS_GOV_API_KEY=""
